{
    "cli": {
        "version": ">= 16.28.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle"
            },
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_API_URL": "https://tsolution.kz"
            }
        },
        "production": {
            "autoIncrement": true,
            "distribution": "store",
            "channel": "production",
            "env": {
                "EXPO_PUBLIC_API_URL": "https://tsolution.kz"
            },
            "android": {
                "buildType": "app-bundle"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "appleId": "your@apple.com",
                "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
                "appleTeamId": "YOUR_TEAM_ID"
            },
            "android": {
                "serviceAccountKeyPath": "./google-service-account.json",
                "track": "internal"
            }
        }
    }
}
