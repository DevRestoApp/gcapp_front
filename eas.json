{
    "cli": {
        "version": ">= 16.28.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle",
                "image": "latest"
            },
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_API_URL": "https://tsolution.kz",
                "EXPO_PUBLIC_SKIP_LOCATION_CHECK": "true"
            }
        },
        "production": {
            "autoIncrement": true,
            "distribution": "store",
            "channel": "production",
            "env": {
                "EXPO_PUBLIC_API_URL": "https://tsolution.kz",
                "EXPO_PUBLIC_SKIP_LOCATION_CHECK": "false"
            },
            "android": {
                "buildType": "app-bundle",
                "image": "latest"
            },
            "ios": {
                "autoIncrement": true,
                "image": "latest",
                "credentialsSource": "remote"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "appleId": "qoqosyk@icloud.com",
                "ascAppId": "6763617009",
                "appleTeamId": "DKW4W7R992"
            },
            "android": {
                "serviceAccountKeyPath": "./google-service-account.json",
                "track": "internal"
            }
        }
    }
}
